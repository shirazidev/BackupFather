# ---------------------------------------------------------------------------
# backupfather configuration — copy to .env and fill in.
# Never commit a real .env. Secrets are never logged by the app.
# ---------------------------------------------------------------------------

# --- Postgres source(s) ---
# Comma-separated list of `name:dsn`. Names must be alphanumeric/-/_.
DATABASES=main:postgres://user:pass@db:5432/appdb,secondary:postgres://user:pass@db:5432/other
PG_DUMP_FORMAT=custom          # custom|plain|directory

# --- Scheduling ---
SCHEDULER_ENABLED=true         # false -> drive with external cron / k8s CronJob + `run --once`
BACKUP_CRON=0 3 * * *          # UTC

# --- Compression / encryption ---
COMPRESSION=gzip               # gzip|zstd|none  (zstd needs the [zstd] extra)
COMPRESSION_LEVEL=6            # gzip 1-9, zstd 1-22
ENCRYPTION_ENABLED=false
ENCRYPTION_METHOD=gpg          # gpg|aes
GPG_RECIPIENT=                 # required if ENCRYPTION_METHOD=gpg
AES_PASSPHRASE=                # required if ENCRYPTION_METHOD=aes

# --- Destinations (comma-separated: telegram,bale,email,local) ---
DESTINATIONS=telegram,email

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MAX_UPLOAD_MB=50      # ~50MB bot API limit; larger files are auto-split

BALE_BOT_TOKEN=
BALE_CHAT_ID=
BALE_MAX_UPLOAD_MB=50          # verify Bale's current limit; often lower than Telegram

SMTP_HOST=
SMTP_PORT=587                  # 465 -> implicit SSL, otherwise STARTTLS when SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=                       # comma-separated recipients
SMTP_USE_TLS=true
SMTP_MAX_ATTACHMENT_MB=20      # larger dumps skip email (use a storage destination)

# --- Notifications (independent of where the backup file goes) ---
NOTIFY_ON_SUCCESS=true
NOTIFY_ON_FAILURE=true
NOTIFIER_TELEGRAM_CHAT_ID=     # set to send status pings via Telegram (reuses TELEGRAM_BOT_TOKEN)
NOTIFIER_EMAIL_ENABLED=false   # set true to also email status (reuses SMTP_* settings)

# --- Retention (local only; remote channels can't list/delete) ---
RETENTION_DAYS=14
RETENTION_COUNT=               # optional: keep last N per database

# --- Storage ---
LOCAL_BACKUP_DIR=/backups

# --- Logging / health ---
LOG_LEVEL=INFO
LOG_FORMAT=text                # text|json
HEALTHCHECK_ENABLED=true
HEALTHCHECK_PORT=8080
